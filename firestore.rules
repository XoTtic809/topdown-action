rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
    }

    // ── Banned list ────────────────────────────────────────
    match /banned/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── Admins (read-only from client) ─────────────────────
    match /admins/{userId} {
      allow read: if request.auth != null;
    }

    // ── Leaderboards ───────────────────────────────────────
    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /coinsLeaderboard/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /levelLeaderboard/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Marketplace listings ───────────────────────────────
    match /marketplace/{listingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null;
    }

    // ── Marketplace whitelist ──────────────────────────────
    match /marketplaceWhitelist/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── Trade logs ─────────────────────────────────────────
    match /tradeLogs/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // ── Trade restrictions ─────────────────────────────────
    match /tradeRestrictions/{skinId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── Activity logs ──────────────────────────────────────
    match /activityLogs/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // ── Flagged scores (anticheat) ─────────────────────────
    match /flaggedScores/{flagId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── Announcements ──────────────────────────────────────
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ── Price overrides (admin only) ───────────────────────
    match /skinPriceOverrides/{skinId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    match /cratePriceOverrides/{crateId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
  }
}
